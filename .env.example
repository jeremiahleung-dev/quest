# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com/dashboard
# Then copy these values from: Project Settings > API

# Your project's REST/Auth endpoint
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# The public "anon" key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase setup checklist ─────────────────────────────────────────────────
# 1. Authentication > Providers > Email: enable "Confirm email" (already on by default)
# 2. Authentication > Providers > Google: enable and add your Google OAuth credentials
#    (Create OAuth credentials at https://console.cloud.google.com)
#    Callback URL for Google: https://<your-project-id>.supabase.co/auth/v1/callback
# 3. Authentication > URL Configuration:
#    - Site URL: your production URL (e.g. https://quest.vercel.app)
#    - Redirect URLs: add your production URL + http://localhost:5173 for dev
# 4. Deploy these env vars to Vercel:
#    vercel env add VITE_SUPABASE_URL
#    vercel env add VITE_SUPABASE_ANON_KEY

# ─── NEVER commit a real .env file ────────────────────────────────────────────
# The actual .env file is in .gitignore. This file is the template only.
